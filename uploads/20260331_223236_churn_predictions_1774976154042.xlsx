<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Customer Churn Prediction System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .prediction-card {
            transition: all 0.3s ease;
        }
        .prediction-card:hover {
            transform: translateY(-2px);
        }
        .file-upload-area {
            border: 2px dashed var(--bs-border-color);
            border-radius: 8px;
            padding: 2rem;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .file-upload-area:hover {
            border-color: var(--bs-primary);
            background-color: var(--bs-body-bg);
        }
        .file-upload-area.dragover {
            border-color: var(--bs-success);
            background-color: var(--bs-success-bg-subtle);
        }
        .nav-tabs .nav-link.active {
            background-color: var(--bs-primary);
            border-color: var(--bs-primary);
        }
        .progress {
            display: none;
        }
        .progress.show {
            display: block;
        }
        .prediction-result {
            font-size: 1.2em;
            font-weight: bold;
        }
        .confidence-badge {
            font-size: 0.9em;
        }
        .result-icon {
            font-size: 2em;
            margin-bottom: 10px;
        }
        .result-stays {
            color: var(--bs-success);
        }
        .result-exits {
            color: var(--bs-danger);
        }
    </style>
</head>
<body data-bs-theme="light">
    <div class="container-fluid">
        <!-- Header -->
        <div class="row">
            <div class="col-12">
                <div class="bg-primary text-white p-4 mb-4">
                    <div class="container">
                        <h1 class="display-6 mb-0">
                            <i class="fas fa-chart-line me-3"></i>
                            Customer Churn Prediction System
                        </h1>
                        <p class="lead mb-0">Predict customer behavior using machine learning model</p>
                        
                    </div>
                </div>
            </div>
        </div>

        <!-- Flash Messages -->
        
            
        

        <!-- Main Content -->
        <div class="container">
            <!-- Navigation Tabs -->
            <ul class="nav nav-tabs mb-4" id="predictionTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="single-tab" data-bs-toggle="tab" data-bs-target="#single-prediction" type="button" role="tab">
                        <i class="fas fa-user me-2"></i>Single Prediction
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="batch-tab" data-bs-toggle="tab" data-bs-target="#batch-prediction" type="button" role="tab">
                        <i class="fas fa-file-excel me-2"></i>Batch Prediction
                    </button>
                </li>
            </ul>

            <!-- Tab Content -->
            <div class="tab-content" id="predictionTabsContent">
                <!-- Single Prediction Tab -->
                <div class="tab-pane fade show active" id="single-prediction" role="tabpanel">
                    <div class="row">
                        <!-- Input Form -->
                        <div class="col-lg-6">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="fas fa-edit me-2"></i>Customer Information
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <form action="/predict" method="POST">
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label for="credit_score" class="form-label">Credit Score</label>
                                                <input type="number" class="form-control" id="credit_score" name="credit_score" 
                                                       min="300" max="850" value="600" required>
                                                <div class="form-text">300 - 850</div>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="geography" class="form-label">Geography</label>
                                                <select class="form-select" id="geography" name="geography" required>
                                                    <option value="0" >France</option>
                                                    <option value="1" >Germany</option>
                                                    <option value="2" >India</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="gender" class="form-label">Gender</label>
                                                <select class="form-select" id="gender" name="gender" required>
                                                    <option value="0" >Female</option>
                                                    <option value="1" >Male</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="age" class="form-label">Age</label>
                                                <input type="number" class="form-control" id="age" name="age" 
                                                       min="18" max="100" value="35" required>
                                                <div class="form-text">18 - 100 years</div>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="tenure" class="form-label">Tenure (Years)</label>
                                                <input type="number" class="form-control" id="tenure" name="tenure" 
                                                       min="0" max="10" value="2" required>
                                                <div class="form-text">Years with bank</div>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="balance" class="form-label">Balance</label>
                                                <input type="number" class="form-control" id="balance" name="balance" 
                                                       min="0" step="0.01" value="0" required>
                                                <div class="form-text">Account balance</div>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="num_products" class="form-label">Number of Products</label>
                                                <select class="form-select" id="num_products" name="num_products" required>
                                                    <option value="1" >1</option>
                                                    <option value="2" >2</option>
                                                    <option value="3" >3</option>
                                                    <option value="4" >4</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="has_credit_card" class="form-label">Has Credit Card</label>
                                                <select class="form-select" id="has_credit_card" name="has_credit_card" required>
                                                    <option value="0" >No</option>
                                                    <option value="1" >Yes</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="is_active_member" class="form-label">Active Member</label>
                                                <select class="form-select" id="is_active_member" name="is_active_member" required>
                                                    <option value="0" >No</option>
                                                    <option value="1" >Yes</option>
                                                </select>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <label for="estimated_salary" class="form-label">Estimated Salary</label>
                                                <input type="number" class="form-control" id="estimated_salary" name="estimated_salary" 
                                                       min="0" step="0.01" value="50000" required>
                                                <div class="form-text">Annual salary estimate</div>
                                            </div>
                                        </div>
                                        <button type="submit" class="btn btn-primary w-100" >
                                            <i class="fas fa-magic me-2"></i>Predict Churn
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <!-- Results -->
                        <div class="col-lg-6">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="fas fa-chart-bar me-2"></i>Prediction Results
                                    </h5>
                                </div>
                                <div class="card-body">
                                    
                                        <div class="text-center py-5">
                                            <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                                            <h5 class="text-muted">No Prediction Yet</h5>
                                            <p class="text-muted">Fill out the customer information form and click "Predict Churn" to see results.</p>
                                        </div>
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Batch Prediction Tab -->
                <div class="tab-pane fade" id="batch-prediction" role="tabpanel">
                    <div class="row">
                        <div class="col-lg-8 mx-auto">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">
                                        <i class="fas fa-file-upload me-2"></i>Batch Prediction from Excel/CSV
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <form id="batchForm" action="/batch_predict" method="POST" enctype="multipart/form-data">
                                        <!-- File Upload Area -->
                                        <div id="fileUploadArea" class="file-upload-area mb-4">
                                            <i class="fas fa-cloud-upload-alt fa-3x text-muted mb-3"></i>
                                            <h5>Drop your Excel or CSV file here</h5>
                                            <p class="text-muted mb-3">Or click to browse and select a file</p>
                                            <p class="small text-muted">
                                                Supported formats: .xlsx, .xls, .csv (Max size: 16MB)
                                            </p>
                                            <input type="file" id="excel_file" name="excel_file" class="d-none" accept=".xlsx,.xls,.csv">
                                        </div>

                                        <!-- Selected File Info -->
                                        <div id="selectedFileInfo" class="alert alert-success" style="display: none;">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <i class="fas fa-file-excel me-2"></i>
                                                    <strong id="selectedFileName"></strong>
                                                    <span class="text-muted">(<span id="selectedFileSize"></span>)</span>
                                                </div>
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="clearSelectedFile()">
                                                    <i class="fas fa-times"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Progress Bar -->
                                        <div id="uploadProgress" class="progress mb-4">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
                                        </div>

                                        <!-- Submit Button -->
                                        <button id="batchSubmitBtn" type="submit" class="btn btn-primary w-100" disabled >
                                            <i class="fas fa-magic me-2"></i>Process File & Predict
                                        </button>
                                    </form>

                                    <!-- Template Downloads -->
                                    <div class="mt-4 pt-4 border-top">
                                        <h6><i class="fas fa-download me-2"></i>Download Sample Templates</h6>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <a href="/download_template/excel" class="btn btn-outline-success w-100 mb-2">
                                                    <i class="fas fa-file-excel me-2"></i>Excel Template
                                                </a>
                                            </div>
                                            <div class="col-md-6">
                                                <a href="/download_template/csv" class="btn btn-outline-info w-100 mb-2">
                                                    <i class="fas fa-file-csv me-2"></i>CSV Template
                                                </a>
                                            </div>
                                        </div>
                                        <small class="text-muted">
                                            Download these templates to see the required data format for batch predictions.
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Custom JS -->
    <script src="/static/js/main.js"></script>
</body>
</html>